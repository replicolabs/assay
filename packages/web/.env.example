# Base URL of the gateway API. Empty/unset = relative paths (only correct if
# frontend and gateway share an origin, which they don't in production).
#
# Local dev (gateway running via `npm run dev` in packages/gateway):
VITE_API_BASE_URL=http://127.0.0.1:8080

# Production (Vercel): set to the deployed Railway gateway URL, e.g.
#   VITE_API_BASE_URL=https://api.useassay.xyz

# Force the UI to use bundled fixture data instead of calling the gateway at
# all (handy for a demo link that always works). Same effect as a `?mock=1`
# query param at runtime, without needing to set this at build time.
# VITE_USE_FIXTURES=true
