# --- Postgres ---
# Local dev via docker-compose:
#   DATABASE_URL=postgres://assay:assay@localhost:5432/assay
# Production (e.g. Neon): use a direct host, not a transaction-mode pooler —
# both services keep their own persistent connection pool already, and sqlx's
# server-side prepared statements aren't compatible with transaction pooling.
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# --- OKX.AI integration ---
# fake  = run against packages/gateway/test/fakes/onchainos, no live network or
#         wallet needed. Useful for local development and CI.
# live  = shell out to the real `onchainos` CLI (must be installed and logged in).
ONCHAINOS_MODE=fake
ONCHAINOS_BIN=onchainos

# OKX Onchain OS Developer Portal credentials (web3.okx.com/onchain-os/dev-portal).
# A personal key raises rate limits above the CLI's shared default. These are read
# directly from the process environment by the `onchainos` binary — quote any value
# containing `#`, `$`, or whitespace so it isn't misparsed.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Assay's own two OKX.AI agent identities — a User Agent identity for paying canary
# task budgets, and an ASP identity for listing Assay's own lookup/assessment
# service. Create with `onchainos agent create --role user|asp`.
ASSAY_BUYER_AGENT_ID=
ASSAY_ASP_AGENT_ID=

# --- x402 payments (Agent-to-MCP fast lookup) ---
X402_NETWORK=eip155:196
ASSAY_ASP_PAYOUT_ADDRESS=
X402_ASSET_ADDRESS=
# EIP-712 domain of the asset token (accepts[].extra), required by the `exact`
# scheme's signing path. Defaults match XLayer USDT (USD₮0).
X402_ASSET_NAME=USD₮0
X402_ASSET_VERSION=1
X402_LOOKUP_PRICE_ATOMIC=10000
# Public base URL this gateway is reachable at — used to build the 402
# challenge's resource.url as an absolute URL, per OKX's own spec.
GATEWAY_PUBLIC_BASE_URL=https://api.useassay.xyz
# OKX's own x402 facilitator (verify + settle incoming payments) —
# web3.okx.com/onchainos/dev-docs/payments/api-http-batch. Reuses the same
# OKX_API_KEY/SECRET_KEY/PASSPHRASE above (same Developer Portal credentials
# as the onchainos CLI login) — set all three, or /v1/lookup fails closed on
# every paid request (verify/settle never called). Override only if OKX ever
# needs a different key scope for payments than for the CLI.
X402_FACILITATOR_BASE_URL=https://web3.okx.com

# --- A2A negotiation auto-responder ---
# When true (live mode only), Assay automatically sends the fixed OKX-defined
# cold-start opener (`agent contact-user`) to any new task designating our ASP
# identity, so a counterparty is never left waiting on a manual response. Off
# by default even in live mode — this sends a real message to a real
# counterparty, so enabling it is a deliberate, separate decision.
#
# Requires the `okx-a2a` daemon (@okxweb3/a2a-node, bundled in the gateway
# Docker image) to be bootstrapped, which itself needs an authenticated AI
# provider CLI bound to it — Claude Code (@anthropic-ai/claude-code, also
# bundled), authenticated non-interactively via ANTHROPIC_API_KEY below. Set
# both this AND ANTHROPIC_API_KEY, or the daemon bootstrap fails at container
# boot (logged, non-fatal — the rest of the service still starts).
A2A_RESPONDER_ENABLED=false

# --- Evaluation Engine (Rust service) ---
ENGINE_HTTP_ADDR=127.0.0.1:8081
ENGINE_URL=http://127.0.0.1:8081
# How often the background worker recomputes decayed scores, in seconds (default 300).
# ENGINE_WORKER_INTERVAL_SECS=300

# --- Gateway (TS service) ---
GATEWAY_HTTP_ADDR=127.0.0.1:8080

# --- LLM (task intake / acceptance-criteria generation) ---
ANTHROPIC_API_KEY=
